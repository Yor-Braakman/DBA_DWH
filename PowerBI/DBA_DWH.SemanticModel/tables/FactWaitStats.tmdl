table FactWaitStats
	lineageTag: 387141ce-9fc6-43e4-96ce-f8a56f41719a

	measure 'Total Wait (ms)' = SUM(FactWaitStats[TotalWaitTimeMs])
		formatString: #,0.00
		displayFolder: Waits
		lineageTag: fdbcb608-a9a8-4046-bb6a-97fe4d2c332f

	measure 'Avg Wait (ms)' = AVERAGE(FactWaitStats[AvgWaitTimeMs])
		formatString: #,0.00
		displayFolder: Waits
		lineageTag: ea131069-d164-42dc-8b41-5635ec324929

	measure 'Waits per Execution (ms)' = DIVIDE([Total Wait (ms)], [Total Executions])
		formatString: #,0.00
		displayFolder: Waits
		lineageTag: e7931c15-6015-4be2-83fc-6d5567de4548

	column RuntimeStatsIntervalId
