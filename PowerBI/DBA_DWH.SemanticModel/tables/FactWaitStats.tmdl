		source = DATATABLE("RuntimeStatsIntervalId", INTEGER, "TenantName", STRING, "ServerName", STRING, "DatabaseName", STRING, "QueryId", INTEGER, "PlanId", INTEGER, "WaitCategory", STRING, "TotalWaitTimeMs", DOUBLE, "AvgWaitTimeMs", DOUBLE, "CountWaits", INTEGER, {{1, "DemoTenant", "DemoServer", "DemoDb", 1, 1, "CPU", 850.0, 85.0, 10}})

