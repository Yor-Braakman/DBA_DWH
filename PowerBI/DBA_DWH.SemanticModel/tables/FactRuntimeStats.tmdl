	partition FactRuntimeStats = calculated
		mode: import
		source = DATATABLE("RuntimeStatsIntervalId", INTEGER, "TenantName", STRING, "ServerName", STRING, "DatabaseName", STRING, "QueryId", INTEGER, "PlanId", INTEGER, "CountExecutions", INTEGER, "AvgDurationMs", DOUBLE, "AvgCpuTimeMs", DOUBLE, "AvgLogicalIoReads", DOUBLE, "AvgLogicalIoWrites", DOUBLE, "IsRegression", BOOLEAN, {{1, "DemoTenant", "DemoServer", "DemoDb", 1, 1, 10, 125.5, 42.2, 18.0, 4.0, FALSE}})

