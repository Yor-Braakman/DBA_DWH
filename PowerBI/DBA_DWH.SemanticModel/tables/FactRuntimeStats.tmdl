table FactRuntimeStats
	lineageTag: 146621bf-150a-44ba-9695-a853ef5df121

	measure 'Total Executions' = SUM(FactRuntimeStats[CountExecutions])
		formatString: #,0
		displayFolder: Performance
		lineageTag: 7cb20947-f5f9-43bf-9b24-3965e58907b9

	measure 'Avg Duration (ms)' = AVERAGE(FactRuntimeStats[AvgDurationMs])
		formatString: #,0.00
		displayFolder: Performance
		lineageTag: b2bf684f-6e92-43a9-9ba2-5aac700083fc

	measure 'Total CPU (ms)' = SUMX(FactRuntimeStats, FactRuntimeStats[AvgCpuTimeMs] * FactRuntimeStats[CountExecutions])
		formatString: #,0.00
		displayFolder: Performance
		lineageTag: 8d0b6cd7-69a5-4f0d-8f13-0f800d8cf168

	measure 'CPU per Execution (ms)' = DIVIDE([Total CPU (ms)], [Total Executions])
		formatString: #,0.00
		displayFolder: Efficiency
		lineageTag: b3998472-7bbe-47ab-a120-81e0a2472674

	measure 'Avg Logical Reads' = AVERAGE(FactRuntimeStats[AvgLogicalIoReads])
		formatString: #,0.00
		displayFolder: IO
		lineageTag: 103fc451-0376-48c4-baed-fabc04fde8fc

	measure 'Avg Logical Writes' = AVERAGE(FactRuntimeStats[AvgLogicalIoWrites])
		formatString: #,0.00
		displayFolder: IO
		lineageTag: 0b8ad70a-40d3-4a8c-a93d-4d94fc07ad3b

	measure 'Regression Query Count' = CALCULATE(DISTINCTCOUNT(FactRuntimeStats[QueryId]), FactRuntimeStats[IsRegression] = TRUE())
		formatString: #,0
		displayFolder: Regression
		lineageTag: aeef5676-3a35-4eb5-b8f4-88f98d6a1d7f

	measure 'Regression Rate %' = DIVIDE([Regression Query Count], DISTINCTCOUNT(FactRuntimeStats[QueryId]))
		formatString: 0.00%
		displayFolder: Regression
		lineageTag: 49353d7b-5b38-411c-8045-58343b55479a

	measure 'Top Query Rank by Duration' = RANKX(ALL(DimQuery[QueryId]), [Avg Duration (ms)],, DESC, DENSE)
		formatString: #,0
		displayFolder: Ranking
		lineageTag: 4c5fea58-8dd1-4413-9049-53c0ce558143

